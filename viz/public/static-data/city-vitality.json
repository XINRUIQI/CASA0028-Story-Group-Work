{
  "description": "Composite City Vitality Density Index — blended from route-level and city-wide indicators",
  "formula": {
    "weights": {
      "service_freq": 0.30,
      "support_access": 0.30,
      "service_certainty": 0.20,
      "safety_visibility": 0.20
    },
    "normalization": "Each component normalized to 0–1. service_freq = 1 − waiting_burden / max_waiting. support_access = avg support_ratio blended with city-wide POI data. certainty = 1 − uncertainty_pct / 100. safety = avg safety_score_pct / 100."
  },
  "routes_averaged": [
    "Euston Square → Seven Sisters",
